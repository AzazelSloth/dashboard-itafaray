# Copier ce fichier en ".env" et renseigner vos valeurs.
# Nom de domaine pointant (enregistrement DNS A) vers l'IP publique de l'instance EC2.
DOMAIN=itafaray.exemple.mg
# Adresse e-mail pour les notifications Let's Encrypt (expiration de certificat).
EMAIL=contact@exemple.mg

# =====================================================================
#  E-Notification UGD (SMS / WhatsApp / Email) — module e_notification.R
#  Renseigner les vraies valeurs dans .env (NON versionné).
# =====================================================================
EN_BASE_URL=https://e-notification-gateway.tsirylab.com/api/v1
# Identifiants du service « Santé Pivot » (fournis par l'UGD)
EN_USER=
EN_PASS=
EN_SERVICE_ID=
EN_AGENT_ID=
EN_CATEGORY_ID=
# Identifiants des canaux (fournis par l'UGD)
EN_CH_SMS=
EN_CH_WHATSAPP=
EN_CH_EMAIL=
# Garde-fous :
# - EN_ENABLED=false par défaut pour éviter tout envoi réel accidentel.
# - EN_TEST_TARGET est utile en dev pour forcer tous les envois vers une cible
#   de test. En pré-prod / prod, laissez cette variable vide ou absente pour
#   utiliser les destinataires saisis dans l'interface.
EN_ENABLED=false
EN_TEST_TARGET=
# Suivi optionnel du statut final après soumission.
# Durée maximale d'attente (secondes) et intervalle de sondage.
EN_STATUS_WAIT_SEC=12
EN_STATUS_POLL_SEC=3
# Journal de debug local pour comparer les appels Shiny avec Swagger.
# Laisser vide pour desactiver le log.
EN_DEBUG_LOG=output/e_notification_debug.log

# =====================================================================
#  X-Road et declenchement OpenFn du rafraichissement du cache
# =====================================================================
XROAD_BASE_URL=https://ss.operator.xroad.digital.gov.mg
XROAD_CLIENT_HEADER=MG/GOV/UGD-MANAGEMENT/primature
XROAD_SERVICE_PATH=MG/GOV/ONGMedicalePivot/SBE/hapifhir
XROAD_ALLOW_INSECURE_TLS=false
XROAD_CACHE_PATH=/data/xroad/xroad_cache.rds
# Secret long et aleatoire, partage uniquement avec le credential OpenFn.
OPENFN_INGEST_TOKEN=
